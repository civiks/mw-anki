# DevTools → Network tab → click any /lapi/ request → Request Headers → copy the full "cookie:" value
MW_COOKIE=your_full_cookie_string_here

# Free Merriam-Webster Collegiate Dictionary API key → https://dictionaryapi.com/register
# Source of real definitions, pronunciation, etymology, and example sentences.
MW_DICT_KEY=your_mw_dictionary_api_key_here

# Free Merriam-Webster Collegiate Thesaurus API key (request alongside the dictionary key).
# Source of authoritative synonyms and antonyms.
MW_THESAURUS_KEY=your_mw_thesaurus_api_key_here
